    e.preventDefault();
    setIsLoading(true);
    setError('');

    try {
      if (isSignUp) {
        const { data: authData, error: authError } = await supabase.auth.signUp({
          email,
          password,
        });

        if (authError) throw authError;

        if (authData.user) {
          const { error: dbError } = await supabase
            .from('lecturers')
            .insert([
              { 
                id: authData.user.id, 
                email: email, 
                full_name: fullName, 
                department: department 
